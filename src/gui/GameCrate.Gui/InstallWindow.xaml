<Window x:Class="GameCrate.Gui.InstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install game in sandbox"
        Height="480" Width="560"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Sandboxed install" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="The installer runs monitored (not LPAC). Game play is still sandboxed. Approve UAC if prompted."
                       Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Display name" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Padding="8" Margin="0,0,0,12"/>

            <TextBlock Text="Profile ID (lowercase letters, numbers, hyphens)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="IdBox" Padding="8" Margin="0,0,0,12"/>

            <TextBlock Text="Install directory (empty folder)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InstallDirBox" Grid.Column="0" Padding="8" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Padding="12,8" Click="BrowseInstallDir_Click"/>
            </Grid>

            <TextBlock Text="Installer (.exe)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InstallerBox" Grid.Column="0" Padding="8" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Padding="12,8" Click="BrowseInstaller_Click"/>
            </Grid>

            <CheckBox x:Name="VirtualAppDataCheck" Content="Virtualize AppData (recommended)"
                      IsChecked="True" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
            <CheckBox x:Name="NetworkCheck" Content="Allow network during install"
                      Foreground="{StaticResource TextBrush}"/>
        </StackPanel>

        <ProgressBar x:Name="InstallProgress" Grid.Row="2" Height="4" Margin="0,16,0,8"
                     IsIndeterminate="False" Visibility="Collapsed"/>

        <TextBlock x:Name="InstallStatus" Grid.Row="2" Margin="0,16,0,8"
                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Visibility="Visible"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="InstallStartButton" Content="Install" Padding="16,8"
                    Click="InstallStartButton_Click" IsDefault="True"
                    Background="{StaticResource AccentBrush}" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
